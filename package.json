{
    "name": "mcp-audit",
    "version": "0.1.0",
    "description": "CLI security scanner for MCP (Model Context Protocol) servers",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "mcp-audit": "./bin/mcp-audit.js"
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/ tests/",
        "dev": "tsup --watch"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "keywords": [
        "mcp",
        "security",
        "scanner",
        "model-context-protocol",
        "cli",
        "static-analysis",
        "vulnerability"
    ],
    "author": "",
    "license": "MIT",
    "files": [
        "dist/",
        "bin/",
        "data/"
    ],
    "repository": {
        "type": "git",
        "url": ""
    },
    "devDependencies": {
        "@types/babel__traverse": "^7.28.0",
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "@babel/parser": "^7.29.2",
        "@babel/traverse": "^7.29.0",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "chalk": "^5.6.2",
        "cli-table3": "^0.6.5",
        "commander": "^14.0.3",
        "fast-glob": "^3.3.3",
        "ora": "^9.3.0"
    }
}
